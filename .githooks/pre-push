#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

should_run_checks=0

while read -r local_ref _local_sha remote_ref _remote_sha; do
  branch_name=""

  if [[ "$local_ref" == refs/heads/* ]]; then
    branch_name="${local_ref#refs/heads/}"
  elif [[ "$remote_ref" == refs/heads/* ]]; then
    branch_name="${remote_ref#refs/heads/}"
  fi

  case "$branch_name" in
    main|prod|release*)
      should_run_checks=1
      ;;
  esac
done

if [[ "$should_run_checks" -eq 0 ]]; then
  exit 0
fi

echo "pre-push: running Hermes CLI prod-branch guardrails"

if [[ -x venv/bin/python ]]; then
  test_runner=(venv/bin/python -m pytest)
elif [[ -x "${HOME}/.hermes/hermes-agent/venv/bin/python" ]]; then
  test_runner=("${HOME}/.hermes/hermes-agent/venv/bin/python" -m pytest)
elif command -v uv >/dev/null 2>&1; then
  test_runner=(uv run --python 3.11 python -m pytest)
elif command -v python3 >/dev/null 2>&1; then
  test_runner=(python3 -m pytest)
else
  echo "pre-push: could not find a Python test runner" >&2
  exit 1
fi

"${test_runner[@]}" tests/hermes_cli/test_banner.py tests/hermes_cli/test_update_check.py -q
